# AeroDataBox / RapidAPI (required for live airport boards)
RAPIDAPI_KEY=
# Optional override (default: aerodatabox.p.rapidapi.com)
RAPIDAPI_HOST=

# Live aircraft position (optional fallbacks — see getAircraftLivePosition)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
AVIATIONSTACK_API_KEY=
ADSBX_API_KEY=

# Supabase service role — server / PM2 worker only (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Capacitor (native shell): WebView loads this URL. Use your LAN IP for local Next dev, or production HTTPS.
# Example local: http://192.168.1.10:3000
# Example prod: https://www.fiyatrotasi.com
# CAPACITOR_SERVER_URL=

# Canonical site URL for Open Graph and absolute links (set in Vercel → Environment Variables)
# Example: https://your-app.vercel.app
# OAuth: if set, /auth/callback uses this origin only when hostname matches the current page (www/apex OK).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Google / Apple OAuth + push subscription sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Apple Sign In: configure the secret key in Supabase Dashboard (Auth → Apple).
# These are optional here for local docs / CI only — not read by the Next.js app.
APPLE_CLIENT_ID=
APPLE_SECRET=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto:you@domain.com or https://your-domain.com
VAPID_SUBJECT=

# Stripe (Checkout + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=
# Optional overrides (defaults: fiyatrotasi.com). Use http://localhost:3000/... locally.
# STRIPE_CHECKOUT_SUCCESS_URL=https://www.fiyatrotasi.com/premium/success
# STRIPE_CHECKOUT_CANCEL_URL=https://www.fiyatrotasi.com/premium

# PostHog (product analytics; optional — app works without these)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional OAuth debug (server-only)
# DEBUG_OAUTH_SUCCESS=1
