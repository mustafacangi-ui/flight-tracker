# AeroDataBox / RapidAPI (required for live airport boards)
RAPIDAPI_KEY=
# Optional override (default: aerodatabox.p.rapidapi.com)
RAPIDAPI_HOST=

# Live aircraft position (optional fallbacks — see getAircraftLivePosition)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
AVIATIONSTACK_API_KEY=
ADSBX_API_KEY=

# Supabase service role — server / PM2 worker only (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Capacitor (native shell): WebView loads this URL. Use your LAN IP for local Next dev, or production HTTPS.
# Example local: http://192.168.1.10:3000
# Example prod: https://www.fiyatrotasi.com
# CAPACITOR_SERVER_URL=

# Canonical site URL for Open Graph and absolute links (set in Vercel → Environment Variables)
# Example: https://your-app.vercel.app
# OAuth: if set, /auth/callback uses this origin only when hostname matches the current page (www/apex OK).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Release / QA labels (optional; shown on /debug/release-check)
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_RELEASE_CHANNEL=

# Supabase (Google / Apple OAuth + push subscription sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Apple Sign In: configure the secret key in Supabase Dashboard (Auth → Apple).
# These are optional here for local docs / CI only — not read by the Next.js app.
APPLE_CLIENT_ID=
APPLE_SECRET=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto:you@domain.com or https://your-domain.com
VAPID_SUBJECT=

# Stripe (Checkout + webhooks)
# Secret API key from Stripe Dashboard → Developers → API keys (sk_test_… / sk_live_…).
# Required for POST /api/stripe/checkout.
STRIPE_SECRET_KEY=
# Webhook signing secret from Developers → Webhooks → your endpoint (whsec_…).
# Required for POST /api/stripe/webhook signature verification.
STRIPE_WEBHOOK_SECRET=
# Optional for hosted Checkout today; useful for Stripe.js / future Elements.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring price IDs (price_…) for Premium — monthly plan.
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
# Recurring price ID for Premium — yearly plan.
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=
# Optional overrides (defaults: fiyatrotasi.com). Use http://localhost:3000/... locally.
# STRIPE_CHECKOUT_SUCCESS_URL=https://www.fiyatrotasi.com/premium/success
# STRIPE_CHECKOUT_CANCEL_URL=https://www.fiyatrotasi.com/premium

# Sentry (error monitoring; optional — app no-ops when DSN is unset)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: server-only DSN override (defaults to NEXT_PUBLIC_SENTRY_DSN when unset)
# SENTRY_DSN=
# Build / release (Vercel can set release via SENTRY_RELEASE or use VERCEL_GIT_COMMIT_SHA)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Browser release label (injected from next.config when SENTRY_RELEASE or VERCEL_GIT_COMMIT_SHA is set)
# NEXT_PUBLIC_SENTRY_RELEASE=
# Optional label for client environment (else NODE_ENV is used)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# PostHog (product analytics; optional — app works without these)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional OAuth debug (server-only)
# DEBUG_OAUTH_SUCCESS=1
